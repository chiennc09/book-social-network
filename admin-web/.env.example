# ── Admin Web — Environment Variables ──────────────────────────────────────────
# Copy to .env.local for local development (git-ignored by Vite by default)
# For Docker builds, these are passed as build args in docker-compose.yml

# API Gateway URL — accessible from the BROWSER (not Docker internal network)
# Local dev:   http://localhost:8888     → proxied by vite (see vite.config.ts)
# Real device: http://192.168.x.x:8888  → your LAN IP
# Production:  https://api.yourdomain.com
VITE_API_GATEWAY_URL=http://localhost:8888

# MinIO Public URL — where MinIO is accessible FROM THE BROWSER
# Files are stored as RELATIVE object keys. The browser builds:
#   fullUrl = {VITE_MINIO_PUBLIC_URL}/{VITE_MINIO_BUCKET}/{objectKey}
#
# Local dev:   http://localhost:9000
# Production:  https://cdn.yourdomain.com
VITE_MINIO_PUBLIC_URL=http://localhost:9000

# MinIO bucket name (must match MINIO_BUCKET_NAME in docker-compose.yml)
VITE_MINIO_BUCKET=book-social-network
