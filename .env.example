# ═══════════════════════════════════════════════════════════════════════════════
# Book Social Network — Docker Compose Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# HOW TO USE:
#   1. Copy this file to .env  (cp .env.example .env)
#   2. Fill in your real secret values
#   3. docker-compose up -d   (Docker Compose automatically reads .env)
#
# This file is gitignored. NEVER commit .env with real secrets.
# ═══════════════════════════════════════════════════════════════════════════════

# ── JWT Secret ───────────────────────────────────────────────────────────────
# HMAC-SHA512 signing key. MUST be the same across identity-service restarts.
# Generate a strong key: openssl rand -base64 64
JWT_SIGNER_KEY=1TjXchw5FloESb63Kc+DFhTARvpWL4jUGCwfGWxuG5SIf/1y/LgJxHnMqaF6A/ij

# ── Email Provider (Brevo / Sendinblue) ───────────────────────────────────────
# Sign up at https://www.brevo.com/ and get your API key
BREVO_API_KEY=xkeysib-your-real-brevo-api-key-here

# ── MinIO (Object Storage) ────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Database Passwords ────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
NEO4J_PASSWORD=12345678

# ── Mobile Media URL ─────────────────────────────────────────────────────────
# Android Emulator:  http://10.0.2.2:9000
# Real Device:       http://192.168.x.x:9000   (your LAN IP)
# Production:        https://cdn.yourdomain.com
MINIO_PUBLIC_URL=http://10.0.2.2:9000
