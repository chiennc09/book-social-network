# Web App Environment Variables
# Copy this file to .env.local for development

# API Gateway URL
# Local development: http://localhost:8888
# Production: https://api.yourdomain.com
VITE_API_URL=http://10.0.2.2:8888

# File Upload Configuration  
VITE_MAX_FILE_SIZE=104857600  # 100MB in bytes
VITE_ALLOW_FILE_TYPES=image/*,application/pdf,application/epub+zip

# Feature Flags
VITE_ENABLE_FILE_UPLOAD=true

# Logging
VITE_LOG_LEVEL=debug  # debug, info, warn, error
