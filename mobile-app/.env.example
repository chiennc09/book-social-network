# ═══════════════════════════════════════════════════════════════════════════════
# Book Social Network — Mobile App Environment Variables
# Copy this file to .env and update values as needed.
#
# NOTE: React Native does NOT auto-load .env without react-native-config.
#       All permanent config lives in:  src/config/env.ts
#       Use this file for documentation / CI pipeline injection.
# ═══════════════════════════════════════════════════════════════════════════════

# ── API Gateway base URL ──────────────────────────────────────────────────────
# Android Emulator  :  http://10.0.2.2:8888     (10.0.2.2 → host localhost)
# Real Device (LAN) :  http://192.168.x.x:8888  (replace with your machine's IP)
# Production        :  https://api.yourdomain.com
REACT_APP_API_URL=http://10.0.2.2:8888

# ── MinIO Public URL (for media access from mobile) ──────────────────────────
# Android Emulator  :  http://10.0.2.2:9000
# Real Device (LAN) :  http://192.168.x.x:9000
# Production        :  https://cdn.yourdomain.com
REACT_APP_MINIO_URL=http://10.0.2.2:9000

# ── File Upload Limits ────────────────────────────────────────────────────────
REACT_APP_MAX_FILE_SIZE=209715200   # 200MB in bytes
REACT_APP_ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf,application/epub+zip

# ── Feature Flags ─────────────────────────────────────────────────────────────
REACT_APP_ENABLE_FILE_UPLOAD=true
REACT_APP_ENABLE_OFFLINE_MODE=false

# ── Logging ───────────────────────────────────────────────────────────────────
REACT_APP_LOG_LEVEL=debug   # debug | info | warn | error
